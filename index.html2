<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Futebol Tracker | Alta Performance</title>

    <style>
        :root {
            --bg-principal: #0f172a;
            --verde-campo: #10b981;
            --verde-hover: #059669;
            --azul-destaque: #3b82f6;
            --azul-hover: #2563eb;
            --cinza-fundo: #f8fafc;
            --cinza-borda: #e2e8f0;
            --texto-escuro: #1e293b;
            --texto-claro: #64748b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #f1f5f9;
            color: var(--texto-escuro);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            padding: 30px 20px;
            text-align: center;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        header h1 {
            font-size: 2.2rem;
            margin-bottom: 8px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        header p {
            color: #94a3b8;
            font-size: 1rem;
            margin-bottom: 20px;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 12px;
            max-width: 500px;
            margin: 0 auto;
        }

        nav button {
            flex: 1;
            padding: 12px 20px;
            border: none;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s ease;
            backdrop-filter: blur(4px);
        }

        nav button:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-1px);
        }

        nav button.btn-active {
            background: var(--verde-campo);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

        nav button.btn-active:hover {
            background: var(--verde-hover);
        }

        .container {
            width: 92%;
            max-width: 1100px;
            margin: 30px auto;
            flex: 1;
        }

        .section {
            display: none;
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05);
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section.active {
            display: block;
        }

        h2 {
            margin-bottom: 20px;
            color: var(--bg-principal);
            font-size: 1.6rem;
            font-weight: 700;
            border-bottom: 2px solid var(--cinza-borda);
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--texto-escuro);
        }

        input, textarea, select {
            width: 100%;
            padding: 12px;
            border: 1.5px solid var(--cinza-borda);
            border-radius: 10px;
            background: var(--cinza-fundo);
            color: var(--texto-escuro);
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: var(--azul-destaque);
            background: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

        button.salvar {
            background: var(--azul-destaque);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2);
        }

        button.salvar:hover {
            background: var(--azul-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .dashboard-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-box {
            background: white;
            padding: 24px;
            text-align: center;
            border-radius: 14px;
            border: 1px solid var(--cinza-borda);
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.02);
            position: relative;
            overflow: hidden;
        }

        .info-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--verde-campo);
        }

        .info-box h3 {
            font-size: 2.2rem;
            color: var(--bg-principal);
            margin-bottom: 5px;
            font-weight: 800;
        }

        .info-box p {
            color: var(--texto-claro);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }

        .card {
            background: white;
            padding: 22px;
            border-radius: 14px;
            border: 1px solid var(--cinza-borda);
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.02);
        }

        .card h3 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: var(--bg-principal);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        ul {
            list-style: none;
            max-height: 250px;
            overflow-y: auto;
            padding-right: 5px;
        }

        li {
            padding: 12px;
            margin-bottom: 10px;
            background: var(--cinza-fundo);
            border-radius: 10px;
            border-left: 4px solid var(--verde-campo);
            font-size: 0.95rem;
            line-height: 1.4;
        }

        li small {
            display: block;
            color: var(--texto-claro);
            margin-top: 4px;
        }

        .mt-4 { margin-top: 25px; }

        footer {
            text-align: center;
            padding: 25px;
            color: var(--texto-claro);
            font-size: 0.9rem;
            border-top: 1px solid var(--cinza-borda);
            background: white;
            margin-top: auto;
        }

        @media(max-width: 768px){
            nav {
                flex-wrap: wrap;
            }
            nav button {
                flex: 1 1 40%;
                padding: 10px;
            }
            .section {
                padding: 20px;
            }
        }
    </style>
</head>
<body>

<header>
    <h1>⚽ Futebol Tracker</h1>
    <p>Gestão de alta performance para atletas focados</p>

    <nav>
        <button id="btn-login" class="btn-active" onclick="mostrar('login')">Login</button>
        <button id="btn-cadastro" onclick="mostrar('cadastro')">Cadastro</button>
        <button id="btn-dashboard" onclick="mostrar('dashboard')">Dashboard</button>
    </nav>
</header>

<div class="container">

    <section id="login" class="section active">
        <h2>Acessar Conta</h2>
        <div class="form-group">
            <label for="loginEmail">E-mail</label>
            <input type="email" id="loginEmail" placeholder="exemplo@email.com">
        </div>
        <div class="form-group">
            <label for="loginSenha">Senha</label>
            <input type="password" id="loginSenha" placeholder="Digite sua senha">
        </div>
        <button class="salvar" onclick="login()">Entrar no Painel</button>
    </section>

    <section id="cadastro" class="section">
        <h2>Criar Perfil de Atleta</h2>
        <div class="form-group">
            <label for="nome">Nome Completo</label>
            <input type="text" id="nome" placeholder="Seu nome">
        </div>
        <div class="form-group">
            <label for="email">E-mail de Acesso</label>
            <input type="email" id="email" placeholder="exemplo@email.com">
        </div>
        <div class="form-group">
            <label for="senha">Defina uma Senha</label>
            <input type="password" id="senha" placeholder="Mínimo 6 caracteres">
        </div>
        <button class="salvar" onclick="cadastrar()">Finalizar Cadastro</button>
    </section>

    <section id="dashboard" class="section">
        <h2 id="boasVindas">Painel do Atleta</h2>

        <div class="dashboard-info">
            <div class="info-box">
                <h3 id="totalTreinos">0</h3>
                <p>Treinos Realizados</p>
            </div>
            <div class="info-box">
                <h3 id="totalRefeicoes">0</h3>
                <p>Refeições Registradas</p>
            </div>
            <div class="info-box">
                <h3 id="pesoAtual">0.0 kg</h3>
                <p>Peso Atual</p>
            </div>
        </div>

        <div class="cards">
            <div class="card">
                <h3>🏃‍♂️ Registrar Treino</h3>
                <div class="form-group">
                    <input type="date" id="dataTreino">
                </div>
                <div class="form-group">
                    <select id="tipoTreino">
                        <option value="Físico">Físico (Academia / Cardio)</option>
                        <option value="Técnico">Técnico (Fundamentos / Passe)</option>
                        <option value="Tático">Tático (Posicionamento)</option>
                        <option value="Jogo">Jogo (Coletivo / Amador)</option>
                    </select>
                </div>
                <div class="form-group">
                    <input type="number" id="duracao" placeholder="Duração (em minutos)">
                </div>
                <div class="form-group">
                    <textarea id="obsTreino" rows="2" placeholder="Observações do rendimento..."></textarea>
                </div>
                <button class="salvar" onclick="registrarTreino()">Salvar Treino</button>
            </div>

            <div class="card">
                <h3>🥗 Registrar Alimentação</h3>
                <div class="form-group">
                    <input type="date" id="dataRefeicao">
                </div>
                <div class="form-group">
                    <textarea id="refeicao" rows="5" placeholder="Descreva os alimentos (Ex: Frango, arroz integral, salada e 1 banana)..."></textarea>
                </div>
                <button class="salvar" onclick="registrarRefeicao()">Salvar Refeição</button>
            </div>

            <div class="card">
                <h3>⚖️ Evolução Física</h3>
                <div class="form-group">
                    <input type="number" step="0.1" id="peso" placeholder="Peso Atual (kg)">
                </div>
                <div class="form-group">
                    <input type="number" step="0.01" id="altura" placeholder="Altura (m)">
                </div>
                <div class="form-group">
                    <textarea id="obsPeso" rows="2" placeholder="Como está se sentindo fisicamente?"></textarea>
                </div>
                <button class="salvar" onclick="registrarPeso()">Salvar Evolução</button>
            </div>
        </div>

        <div class="cards mt-4">
            <div class="card">
                <h3>📋 Histórico de Treinos</h3>
                <ul id="listaTreinos"></ul>
            </div>
            <div class="card">
                <h3>🍽 Histórico de Refeições</h3>
                <ul id="listaRefeicoes"></ul>
            </div>
        </div>

    </section>
</div>

<footer>
    Futebol Tracker © 2026 | Desenvolvido para Campeões
</footer>

<script>
// Dados globais salvos por Usuário
let usuarioLogado = null;
let dadosAtleta = {
    treinos: [],
    refeicoes: [],
    peso: "0.0"
};

// Formata data do padrão americano aaaa-mm-dd para dd/mm/aaaa
function formatarData(dataStr) {
    if(!dataStr) return "Data N/I";
    const partes = dataStr.split('-');
    return `${partes[2]}/${partes[1]}/${partes[0]}`;
}

// Controle de Telas (Navegação dinâmica)
function mostrar(id){
    document.querySelectorAll(".section").forEach(sec => sec.classList.remove("active"));
    document.querySelectorAll("nav button").forEach(btn => btn.classList.remove("btn-active"));

    document.getElementById(id).classList.add("active");
    document.getElementById(`btn-${id}`).classList.add("btn-active");

    if (id === 'dashboard' && !usuarioLogado) {
        alert("Por favor, faça login para ver o dashboard.");
        mostrar('login');
    }
}

// Fluxo de Cadastro
function cadastrar(){
    let nome = document.getElementById("nome").value;
    let email = document.getElementById("email").value.toLowerCase().trim();
    let senha = document.getElementById("senha").value;

    if(!nome || !email || !senha) {
        alert("Preencha todos os campos para cadastrar!");
        return;
    }

    let conta = { nome, email, senha, dados: dadosAtleta };
    localStorage.setItem(`user_${email}`, JSON.stringify(conta));

    alert("Atleta cadastrado com sucesso! Faça seu Login.");
    mostrar("login");
    
    // Limpa campos
    document.getElementById("nome").value = "";
    document.getElementById("email").value = "";
    document.getElementById("senha").value = "";
}

// Fluxo de Login
function login(){
    let email = document.getElementById("loginEmail").value.toLowerCase().trim();
    let senha = document.getElementById("loginSenha").value;

    let contaSalva = JSON.parse(localStorage.getItem(`user_${email}`));

    if(contaSalva && contaSalva.senha === senha){
        usuarioLogado = email;
        dadosAtleta = contaSalva.dados || { treinos: [], refeicoes: [], peso: "0.0" };
        
        document.getElementById("boasVindas").innerText = `Painel do Atleta: ${contaSalva.nome}`;
        
        atualizarLayoutDashboard();
        alert(`Bem-vindo de volta, ${contaSalva.nome}!`);
        mostrar("dashboard");
    } else {
        alert("E-mail ou senha inválidos.");
    }
}

// Salva as alterações feitas nas listas no localStorage
function sincronizarDados() {
    if(usuarioLogado) {
        let conta = JSON.parse(localStorage.getItem(`user_${usuarioLogado}`));
        conta.dados = dadosAtleta;
        localStorage.setItem(`user_${usuarioLogado}`, JSON.stringify(conta));
    }
}

// Atualiza os componentes visuais do dashboard
function atualizarLayoutDashboard() {
    // Atualiza contadores superiores
    document.getElementById("totalTreinos").innerText = dadosAtleta.treinos.length;
    document.getElementById("totalRefeicoes").innerText = dadosAtleta.refeicoes.length;
    document.getElementById("pesoAtual").innerText = dadosAtleta.peso + " kg";

    // Atualiza Histórico de Treinos
    let listaT = document.getElementById("listaTreinos");
    listaT.innerHTML = dadosAtleta.treinos.length === 0 ? "<li>Nenhum treino registrado.</li>" : "";
    dadosAtleta.treinos.forEach(t => {
        listaT.innerHTML += `
            <li>
                <strong>⚽ Tipo: ${t.tipo}</strong> | ⏱ ${t.duracao} min
                <small>📅 Data: ${formatarData(t.data)} <br> 📝 Obs: ${t.obs || 'Nenhuma'}</small>
            </li>
        `;
    });

    // Atualiza Histórico de Refeições
    let listaR = document.getElementById("listaRefeicoes");
    listaR.innerHTML = dadosAtleta.refeicoes.length === 0 ? "<li>Nenhuma refeição registrada.</li>" : "";
    dadosAtleta.refeicoes.forEach(r => {
        listaR.innerHTML += `
            <li>
                🍽 <strong>Refeição:</strong> ${r.descricao}
                <small>📅 Data: ${formatarData(r.data)}</small>
            </li>
        `;
    });
}

// Registrar Novo Treino
function registrarTreino(){
    let data = document.getElementById("dataTreino").value;
    let tipo = document.getElementById("tipoTreino").value;
    let duracao = document.getElementById("duracao").value;
    let obs = document.getElementById("obsTreino").value;

    if(!data || !duracao) {
        alert("Insira a data e a duração do treino!");
        return;
    }

    dadosAtleta.treinos.unshift({ data, tipo, duracao, obs }); // Insere no topo da lista
    sincronizarDados();
    atualizarLayoutDashboard();

    // Limpa campos
    document.getElementById("duracao").value = "";
    document.getElementById("obsTreino").value = "";
}

// Registrar Nova Refeição
function registrarRefeicao(){
    let data = document.getElementById("dataRefeicao").value;
    let descricao = document.getElementById("refeicao").value;

    if(!data || !descricao) {
        alert("Insira a data e a descrição dos alimentos!");
        return;
    }

    dadosAtleta.refeicoes.unshift({ data, descricao });
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("refeicao").value = "";
}

// Registrar Nova Evolução de Peso
function registrarPeso(){
    let peso = document.getElementById("peso").value;

    if(!peso) {
        alert("Por favor, informe seu peso atual.");
        return;
    }

    dadosAtleta.peso = parseFloat(peso).toFixed(1);
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("peso").value = "";
    document.getElementById("obsPeso").value = "";
    alert("Peso atualizado com sucesso!");
}

// Define datas padrão nos inputs para facilitar a usabilidade do usuário
document.getElementById('dataTreino').valueAsDate = new Date();
document.getElementById('dataRefeicao').valueAsDate = new Date();
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Futebol Tracker | Elite Performance</title>

    <style>
        :root {
            --bg-deep: #0b0f19;
            --bg-card: #1e293b;
            --green-neon: #10b981;
            --green-glow: #059669;
            --blue-accent: #3b82f6;
            --yellow-accent: #facc15;
            --red-accent: #ef4444;
            --purple-accent: #8b5cf6;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: rgba(255, 255, 255, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: var(--bg-deep);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-image:
                radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.05) 0px, transparent 50%);
        }

        header {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 25px 20px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header h1 {
            font-size: 2.4rem;
            margin-bottom: 6px;
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #ffffff 0%, #a7f3d0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        header p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 20px;
            font-weight: 500;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 10px;
            max-width: 500px;
            margin: 0 auto;
            background: rgba(15, 23, 42, 0.6);
            padding: 6px;
            border-radius: 14px;
            border: 1px solid var(--border-color);
        }

        nav button {
            flex: 1;
            padding: 10px 16px;
            border: none;
            border-radius: 10px;
            background: transparent;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        nav button:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        nav button.btn-active {
            background: var(--green-neon);
            color: #0b0f19;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

        .container {
            width: 92%;
            max-width: 1100px;
            margin: 40px auto;
            flex: 1;
        }

        .section {
            display: none;
            background: var(--bg-card);
            padding: 35px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.3);
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section.active {
            display: block;
        }

        h2 {
            margin-bottom: 25px;
            color: white;
            font-size: 1.7rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input, textarea, select {
            width: 100%;
            padding: 14px;
            border: 1.5px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            background: rgba(15, 23, 42, 0.5);
            color: white;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: var(--green-neon);
            background: rgba(15, 23, 42, 0.8);
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
        }

        button.salvar {
            background: linear-gradient(135deg, var(--blue-accent) 0%, #2563eb 100%);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
        }

        button.salvar:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
        }

        button.visitante {
            background: transparent;
            color: var(--green-neon);
            border: 2px solid var(--green-neon);
            margin-top: 12px;
        }

        button.visitante:hover {
            background: rgba(16, 185, 129, 0.1);
            transform: translateY(-2px);
        }

        .dashboard-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 35px;
        }

        .info-box {
            background: rgba(15, 23, 42, 0.4);
            padding: 24px;
            text-align: center;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .info-box:hover {
            transform: translateY(-3px);
        }

        .info-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--green-neon), var(--blue-accent));
        }

        .info-box h3 {
            font-size: 2.4rem;
            color: white;
            margin-bottom: 5px;
            font-weight: 800;
        }

        .info-box p {
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }

        .card {
            background: rgba(15, 23, 42, 0.3);
            padding: 25px;
            border-radius: 16px;
            border: 1px solid var(--border-color);
        }

        .card h3 {
            font-size: 1.15rem;
            margin-bottom: 20px;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        ul {
            list-style: none;
            max-height: 280px;
            overflow-y: auto;
            padding-right: 5px;
        }

        ul::-webkit-scrollbar {
            width: 6px;
        }

        ul::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
        }

        li {
            padding: 14px;
            margin-bottom: 12px;
            background: rgba(15, 23, 42, 0.5);
            border-radius: 12px;
            border-left: 4px solid var(--green-neon);
            font-size: 0.95rem;
            line-height: 1.5;
            border-top: 1px solid rgba(255,255,255,0.02);
        }

        li strong {
            color: white;
        }

        li small {
            display: block;
            color: var(--text-muted);
            margin-top: 6px;
        }

        .mt-4 {
            margin-top: 30px;
        }

        .grafico-container {
            width: 100%;
            height: 260px;
            display: flex;
            align-items: flex-end;
            gap: 12px;
            padding: 20px 5px 5px;
            border-bottom: 1px solid var(--border-color);
        }

        .barra-grafico {
            flex: 1;
            min-height: 8px;
            border-radius: 10px 10px 0 0;
            background: linear-gradient(180deg, var(--green-neon), var(--green-glow));
            position: relative;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            transition: height 0.3s ease;
        }

        .barra-grafico span {
            position: absolute;
            top: -24px;
            font-size: 0.8rem;
            color: white;
            font-weight: 700;
        }

        .grafico-labels {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .grafico-labels span {
            flex: 1;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.75rem;
        }

        .meta-item {
            border-left-color: var(--yellow-accent);
        }

        .meta-topo {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
        }

        .meta-topo strong {
            color: white;
        }

        .meta-topo span {
            color: var(--yellow-accent);
            font-weight: 800;
        }

        .barra-meta {
            width: 100%;
            height: 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            overflow: hidden;
        }

        .progresso-meta {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--yellow-accent), var(--green-neon));
        }

        .historico-geral li {
            border-left-color: var(--purple-accent);
        }

        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 999px;
            background: rgba(16, 185, 129, 0.12);
            color: var(--green-neon);
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        footer {
            text-align: center;
            padding: 30px;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-top: 1px solid var(--border-color);
            background: rgba(15, 23, 42, 0.8);
            margin-top: auto;
            letter-spacing: 0.5px;
        }

        @media(max-width: 768px){
            nav {
                flex-wrap: wrap;
            }

            nav button {
                flex: 1 1 40%;
            }

            .section {
                padding: 20px;
            }

            .grafico-container {
                height: 220px;
                gap: 8px;
            }
        }
    </style>
</head>
<body>

<header>
    <h1>⚽ Futebol Tracker</h1>
    <p>Gestão de alta performance para atletas focados</p>

    <nav>
        <button id="btn-login" class="btn-active" onclick="mostrar('login')">Login</button>
        <button id="btn-cadastro" onclick="mostrar('cadastro')">Cadastro</button>
        <button id="btn-dashboard" onclick="mostrar('dashboard')">Dashboard</button>
    </nav>
</header>

<div class="container">

    <section id="login" class="section active">
        <h2>🔒 Acessar Conta</h2>
        <div class="form-group">
            <label for="loginEmail">E-mail</label>
            <input type="email" id="loginEmail" placeholder="exemplo@email.com">
        </div>
        <div class="form-group">
            <label for="loginSenha">Senha</label>
            <input type="password" id="loginSenha" placeholder="Digite sua senha">
        </div>
        <button class="salvar" onclick="login()">Entrar no Painel</button>
        <button class="salvar visitante" onclick="entrarComoVisitante()">Acessar como Visitante (Sem Cadastro)</button>
    </section>

    <section id="cadastro" class="section">
        <h2>📝 Criar Perfil de Atleta</h2>
        <div class="form-group">
            <label for="nome">Nome Completo</label>
            <input type="text" id="nome" placeholder="Seu nome">
        </div>
        <div class="form-group">
            <label for="email">E-mail de Acesso</label>
            <input type="email" id="email" placeholder="exemplo@email.com">
        </div>
        <div class="form-group">
            <label for="senha">Defina uma Senha</label>
            <input type="password" id="senha" placeholder="Mínimo 6 caracteres">
        </div>
        <button class="salvar" style="background: linear-gradient(135deg, var(--green-neon) 0%, #059669 100%); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);" onclick="cadastrar()">Finalizar Cadastro</button>
    </section>

    <section id="dashboard" class="section">
        <h2 id="boasVindas">Painel do Atleta</h2>

        <div class="dashboard-info">
            <div class="info-box">
                <h3 id="totalTreinos">0</h3>
                <p>Treinos Realizados</p>
            </div>
            <div class="info-box">
                <h3 id="totalRefeicoes">0</h3>
                <p>Refeições Registradas</p>
            </div>
            <div class="info-box">
                <h3 id="pesoAtual">0.0 kg</h3>
                <p>Peso Atual</p>
            </div>
        </div>

        <div class="dashboard-info">
            <div class="info-box">
                <h3 id="totalMinutos">0</h3>
                <p>Minutos Treinados</p>
            </div>
            <div class="info-box">
                <h3 id="mediaDuracao">0</h3>
                <p>Média por Treino</p>
            </div>
            <div class="info-box">
                <h3 id="metasConcluidas">0</h3>
                <p>Metas Concluídas</p>
            </div>
        </div>

        <div class="cards">
            <div class="card">
                <h3>🏃‍♂️ Registrar Treino</h3>
                <div class="form-group">
                    <input type="date" id="dataTreino">
                </div>
                <div class="form-group">
                    <select id="tipoTreino">
                        <option value="Físico">Físico (Academia / Cardio)</option>
                        <option value="Técnico">Técnico (Fundamentos / Passe)</option>
                        <option value="Tático">Tático (Posicionamento)</option>
                        <option value="Jogo">Jogo (Coletivo / Amador)</option>
                    </select>
                </div>
                <div class="form-group">
                    <input type="number" id="duracao" placeholder="Duração (em minutos)">
                </div>
                <div class="form-group">
                    <textarea id="obsTreino" rows="2" placeholder="Observações do rendimento..."></textarea>
                </div>
                <button class="salvar" onclick="registrarTreino()">Salvar Treino</button>
            </div>

            <div class="card">
                <h3>🥗 Registrar Alimentação</h3>
                <div class="form-group">
                    <input type="date" id="dataRefeicao">
                </div>
                <div class="form-group">
                    <textarea id="refeicao" rows="5" placeholder="Descreva os alimentos (Ex: Frango, arroz integral, salada e 1 banana)..."></textarea>
                </div>
                <button class="salvar" onclick="registrarRefeicao()">Salvar Refeição</button>
            </div>

            <div class="card">
                <h3>⚖️ Evolução Física</h3>
                <div class="form-group">
                    <input type="number" step="0.1" id="peso" placeholder="Peso Atual (kg)">
                </div>
                <div class="form-group">
                    <input type="number" step="0.01" id="altura" placeholder="Altura (m)">
                </div>
                <div class="form-group">
                    <textarea id="obsPeso" rows="2" placeholder="Como está se sentindo fisicamente?"></textarea>
                </div>
                <button class="salvar" onclick="registrarPeso()">Salvar Evolução</button>
            </div>
        </div>

        <div class="cards mt-4">
            <div class="card">
                <h3>🎯 Criar Meta</h3>
                <div class="form-group">
                    <label for="metaTitulo">Nome da Meta</label>
                    <input type="text" id="metaTitulo" placeholder="Ex: Treinar 5 vezes na semana">
                </div>
                <div class="form-group">
                    <label for="metaTipo">Tipo de Meta</label>
                    <select id="metaTipo">
                        <option value="Treinos">Quantidade de Treinos</option>
                        <option value="Minutos">Minutos de Treino</option>
                        <option value="Refeições">Refeições Registradas</option>
                        <option value="Peso">Peso Alvo</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="metaValor">Valor da Meta</label>
                    <input type="number" step="0.1" id="metaValor" placeholder="Ex: 5, 300 ou 72.5">
                </div>
                <button class="salvar" onclick="registrarMeta()">Salvar Meta</button>
            </div>

            <div class="card">
                <h3>📈 Gráfico de Treinos por Tipo</h3>
                <div id="graficoTreinos" class="grafico-container"></div>
                <div id="labelsGraficoTreinos" class="grafico-labels"></div>
            </div>

            <div class="card">
                <h3>📊 Resumo de Progresso</h3>
                <ul id="resumoProgresso"></ul>
            </div>
        </div>

        <div class="cards mt-4">
            <div class="card">
                <h3>🎯 Minhas Metas</h3>
                <ul id="listaMetas"></ul>
            </div>

            <div class="card">
                <h3>🕒 Histórico Geral</h3>
                <ul id="historicoGeral" class="historico-geral"></ul>
            </div>
        </div>

        <div class="cards mt-4">
            <div class="card">
                <h3>📋 Histórico de Treinos</h3>
                <ul id="listaTreinos"></ul>
            </div>
            <div class="card">
                <h3>🍽 Histórico de Refeições</h3>
                <ul id="listaRefeicoes"></ul>
            </div>
        </div>

    </section>
</div>

<footer>
    Futebol Tracker © 2026 | Desenvolvido para Campeões de Elite
</footer>

<script>
let usuarioLogado = null;
let esVisitante = false;

let dadosAtleta = {
    treinos: [],
    refeicoes: [],
    peso: "0.0",
    historico: [],
    metas: []
};

function criarDadosPadrao(pesoInicial = "0.0") {
    return {
        treinos: [],
        refeicoes: [],
        peso: pesoInicial,
        historico: [],
        metas: []
    };
}

function normalizarDados(dados) {
    return {
        treinos: dados?.treinos || [],
        refeicoes: dados?.refeicoes || [],
        peso: dados?.peso || "0.0",
        historico: dados?.historico || [],
        metas: dados?.metas || []
    };
}

function formatarData(dataStr) {
    if(!dataStr) return "Data N/I";
    const partes = dataStr.split('-');
    return `${partes[2]}/${partes[1]}/${partes[0]}`;
}

function dataHoraAtualFormatada() {
    const agora = new Date();
    return agora.toLocaleString("pt-BR");
}

function mostrar(id){
    if (id === 'dashboard' && !usuarioLogado && !esVisitante) {
        alert("Por favor, faça login ou acesse como visitante para ver o dashboard.");
        mostrar('login');
        return;
    }

    document.querySelectorAll(".section").forEach(sec => sec.classList.remove("active"));
    document.querySelectorAll("nav button").forEach(btn => btn.classList.remove("btn-active"));

    document.getElementById(id).classList.add("active");
    document.getElementById(`btn-${id}`).classList.add("btn-active");
}

function cadastrar(){
    let nome = document.getElementById("nome").value;
    let email = document.getElementById("email").value.toLowerCase().trim();
    let senha = document.getElementById("senha").value;

    if(!nome || !email || !senha) {
        alert("Preencha todos os campos para cadastrar!");
        return;
    }

    let conta = { nome, email, senha, dados: criarDadosPadrao("0.0") };
    localStorage.setItem(`user_${email}`, JSON.stringify(conta));

    alert("Atleta cadastrado com sucesso! Faça seu Login.");
    mostrar("login");

    document.getElementById("nome").value = "";
    document.getElementById("email").value = "";
    document.getElementById("senha").value = "";
}

function login(){
    let email = document.getElementById("loginEmail").value.toLowerCase().trim();
    let senha = document.getElementById("loginSenha").value;

    let contaSalva = JSON.parse(localStorage.getItem(`user_${email}`));

    if(contaSalva && contaSalva.senha === senha){
        usuarioLogado = email;
        esVisitante = false;
        dadosAtleta = normalizarDados(contaSalva.dados);

        document.getElementById("boasVindas").innerText = `⭐ Painel do Atleta: ${contaSalva.nome}`;

        atualizarLayoutDashboard();
        alert(`Bem-vindo de volta, ${contaSalva.nome}!`);
        mostrar("dashboard");
    } else {
        alert("E-mail ou senha inválidos.");
    }
}

function entrarComoVisitante() {
    esVisitante = true;
    usuarioLogado = null;

    dadosAtleta = criarDadosPadrao("75.0");

    document.getElementById("boasVindas").innerText = `🏃‍♂️ Painel do Atleta: Modo Visitante`;
    atualizarLayoutDashboard();
    alert("Acessando como Visitante temporário!");
    mostrar("dashboard");
}

function sincronizarDados() {
    if(usuarioLogado) {
        let conta = JSON.parse(localStorage.getItem(`user_${usuarioLogado}`));
        conta.dados = dadosAtleta;
        localStorage.setItem(`user_${usuarioLogado}`, JSON.stringify(conta));
    }
}

function adicionarHistorico(tipo, descricao) {
    dadosAtleta.historico.unshift({
        tipo,
        descricao,
        dataHora: dataHoraAtualFormatada()
    });

    if(dadosAtleta.historico.length > 30) {
        dadosAtleta.historico = dadosAtleta.historico.slice(0, 30);
    }
}

function calcularTotalMinutos() {
    return dadosAtleta.treinos.reduce((total, treino) => {
        return total + Number(treino.duracao || 0);
    }, 0);
}

function calcularProgressoMeta(meta) {
    let valorAtual = 0;
    let valorMeta = Number(meta.valor);

    if(meta.tipo === "Treinos") {
        valorAtual = dadosAtleta.treinos.length;
    }

    if(meta.tipo === "Minutos") {
        valorAtual = calcularTotalMinutos();
    }

    if(meta.tipo === "Refeições") {
        valorAtual = dadosAtleta.refeicoes.length;
    }

    if(meta.tipo === "Peso") {
        valorAtual = Number(dadosAtleta.peso);
    }

    if(!valorMeta || valorMeta <= 0) return 0;

    let progresso = (valorAtual / valorMeta) * 100;

    if(meta.tipo === "Peso") {
        progresso = valorAtual <= valorMeta ? 100 : Math.max(0, 100 - ((valorAtual - valorMeta) / valorMeta) * 100);
    }

    return Math.min(100, Math.round(progresso));
}

function contarMetasConcluidas() {
    return dadosAtleta.metas.filter(meta => calcularProgressoMeta(meta) >= 100).length;
}

function atualizarLayoutDashboard() {
    const totalMinutos = calcularTotalMinutos();
    const mediaDuracao = dadosAtleta.treinos.length > 0 ? Math.round(totalMinutos / dadosAtleta.treinos.length) : 0;

    document.getElementById("totalTreinos").innerText = dadosAtleta.treinos.length;
    document.getElementById("totalRefeicoes").innerText = dadosAtleta.refeicoes.length;
    document.getElementById("pesoAtual").innerText = dadosAtleta.peso + " kg";
    document.getElementById("totalMinutos").innerText = totalMinutos;
    document.getElementById("mediaDuracao").innerText = mediaDuracao + " min";
    document.getElementById("metasConcluidas").innerText = contarMetasConcluidas();

    atualizarListaTreinos();
    atualizarListaRefeicoes();
    atualizarGraficoTreinos();
    atualizarMetas();
    atualizarHistoricoGeral();
    atualizarResumoProgresso();
}

function atualizarListaTreinos() {
    let listaT = document.getElementById("listaTreinos");
    listaT.innerHTML = dadosAtleta.treinos.length === 0 ? "<li>Nenhum treino registrado.</li>" : "";

    dadosAtleta.treinos.forEach(t => {
        listaT.innerHTML += `
            <li>
                <strong>⚽ Tipo: ${t.tipo}</strong> | ⏱ ${t.duracao} min
                <small>📅 Data: ${formatarData(t.data)} <br> 📝 Obs: ${t.obs || 'Nenhuma'}</small>
            </li>
        `;
    });
}

function atualizarListaRefeicoes() {
    let listaR = document.getElementById("listaRefeicoes");
    listaR.innerHTML = dadosAtleta.refeicoes.length === 0 ? "<li>Nenhuma refeição registrada.</li>" : "";

    dadosAtleta.refeicoes.forEach(r => {
        listaR.innerHTML += `
            <li>
                🍽 <strong>Refeição:</strong> ${r.descricao}
                <small>📅 Data: ${formatarData(r.data)}</small>
            </li>
        `;
    });
}

function atualizarGraficoTreinos() {
    const tipos = ["Físico", "Técnico", "Tático", "Jogo"];
    const contagem = tipos.map(tipo => {
        return dadosAtleta.treinos.filter(treino => treino.tipo === tipo).length;
    });

    const maiorValor = Math.max(...contagem, 1);

    const grafico = document.getElementById("graficoTreinos");
    const labels = document.getElementById("labelsGraficoTreinos");

    grafico.innerHTML = "";
    labels.innerHTML = "";

    tipos.forEach((tipo, index) => {
        const altura = Math.max((contagem[index] / maiorValor) * 100, contagem[index] > 0 ? 12 : 4);

        grafico.innerHTML += `
            <div class="barra-grafico" style="height: ${altura}%">
                <span>${contagem[index]}</span>
            </div>
        `;

        labels.innerHTML += `<span>${tipo}</span>`;
    });
}

function atualizarMetas() {
    let lista = document.getElementById("listaMetas");
    lista.innerHTML = dadosAtleta.metas.length === 0 ? "<li>Nenhuma meta criada ainda.</li>" : "";

    dadosAtleta.metas.forEach((meta, index) => {
        const progresso = calcularProgressoMeta(meta);
        const status = progresso >= 100 ? "Concluída" : "Em andamento";

        lista.innerHTML += `
            <li class="meta-item">
                <div class="meta-topo">
                    <strong>${meta.titulo}</strong>
                    <span>${progresso}%</span>
                </div>
                <div class="barra-meta">
                    <div class="progresso-meta" style="width: ${progresso}%"></div>
                </div>
                <small>Tipo: ${meta.tipo} | Meta: ${meta.valor} | Status: ${status}</small>
                <button class="salvar visitante" onclick="excluirMeta(${index})">Excluir Meta</button>
            </li>
        `;
    });
}

function atualizarHistoricoGeral() {
    let lista = document.getElementById("historicoGeral");
    lista.innerHTML = dadosAtleta.historico.length === 0 ? "<li>Nenhuma atividade registrada ainda.</li>" : "";

    dadosAtleta.historico.forEach(item => {
        lista.innerHTML += `
            <li>
                <span class="badge">${item.tipo}</span>
                <strong>${item.descricao}</strong>
                <small>${item.dataHora}</small>
            </li>
        `;
    });
}

function atualizarResumoProgresso() {
    const totalMinutos = calcularTotalMinutos();
    const maiorTreino = dadosAtleta.treinos.reduce((maior, treino) => {
        return Math.max(maior, Number(treino.duracao || 0));
    }, 0);

    const ultimoTreino = dadosAtleta.treinos[0];
    const ultimaRefeicao = dadosAtleta.refeicoes[0];

    let lista = document.getElementById("resumoProgresso");

    lista.innerHTML = `
        <li><strong>Total treinado:</strong> ${totalMinutos} minutos acumulados.</li>
        <li><strong>Maior treino:</strong> ${maiorTreino} minutos.</li>
        <li><strong>Último treino:</strong> ${ultimoTreino ? `${ultimoTreino.tipo} em ${formatarData(ultimoTreino.data)}` : "Nenhum treino registrado."}</li>
        <li><strong>Última refeição:</strong> ${ultimaRefeicao ? formatarData(ultimaRefeicao.data) : "Nenhuma refeição registrada."}</li>
        <li><strong>Peso atual:</strong> ${dadosAtleta.peso} kg.</li>
    `;
}

function registrarTreino(){
    let data = document.getElementById("dataTreino").value;
    let tipo = document.getElementById("tipoTreino").value;
    let duracao = document.getElementById("duracao").value;
    let obs = document.getElementById("obsTreino").value;

    if(!data || !duracao) {
        alert("Insira a data e a duração do treino!");
        return;
    }

    dadosAtleta.treinos.unshift({ data, tipo, duracao, obs });
    adicionarHistorico("Treino", `${tipo} registrado com ${duracao} minutos`);
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("duracao").value = "";
    document.getElementById("obsTreino").value = "";
}

function registrarRefeicao(){
    let data = document.getElementById("dataRefeicao").value;
    let descricao = document.getElementById("refeicao").value;

    if(!data || !descricao) {
        alert("Insira a data e a descrição dos alimentos!");
        return;
    }

    dadosAtleta.refeicoes.unshift({ data, descricao });
    adicionarHistorico("Refeição", "Nova refeição registrada");
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("refeicao").value = "";
}

function registrarPeso(){
    let peso = document.getElementById("peso").value;

    if(!peso) {
        alert("Por favor, informe seu peso atual.");
        return;
    }

    dadosAtleta.peso = parseFloat(peso).toFixed(1);
    adicionarHistorico("Peso", `Peso atualizado para ${dadosAtleta.peso} kg`);
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("peso").value = "";
    document.getElementById("obsPeso").value = "";
    alert("Peso atualizado com sucesso!");
}

function registrarMeta() {
    let titulo = document.getElementById("metaTitulo").value;
    let tipo = document.getElementById("metaTipo").value;
    let valor = document.getElementById("metaValor").value;

    if(!titulo || !tipo || !valor) {
        alert("Preencha todos os campos da meta!");
        return;
    }

    dadosAtleta.metas.unshift({
        titulo,
        tipo,
        valor
    });

    adicionarHistorico("Meta", `Nova meta criada: ${titulo}`);
    sincronizarDados();
    atualizarLayoutDashboard();

    document.getElementById("metaTitulo").value = "";
    document.getElementById("metaValor").value = "";

    alert("Meta criada com sucesso!");
}

function excluirMeta(index) {
    const meta = dadosAtleta.metas[index];

    if(confirm(`Deseja excluir a meta "${meta.titulo}"?`)) {
        dadosAtleta.metas.splice(index, 1);
        adicionarHistorico("Meta", `Meta excluída: ${meta.titulo}`);
        sincronizarDados();
        atualizarLayoutDashboard();
    }
}

document.getElementById('dataTreino').valueAsDate = new Date();
document.getElementById('dataRefeicao').valueAsDate = new Date();
</script>

</body>
</html>
